<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_library_issued_books" model="ir.actions.act_window">
        <field name="name">Currently Issued</field>
        <field name="res_model">library.book.issue</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','in',('issued','overdue'))]</field>
    </record>

    <record id="action_library_overdue_books" model="ir.actions.act_window">
        <field name="name">Overdue Books</field>
        <field name="res_model">library.book.issue</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','overdue')]</field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_library_issue_list" model="ir.ui.view">
        <field name="name">library.book.issue.list</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <list string="Book Issues"
                  decoration-danger="is_overdue == True"
                  decoration-success="state == 'returned'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="book_id"/>
                <field name="member_id"/>
                <field name="issue_date"/>
                <field name="due_date"/>
                <field name="return_date"/>
                <field name="days_overdue"/>
                <field name="fine_amount"
                       groups="library_management.group_library_reception"/>
                <field name="state" widget="badge"/>
                <field name="is_overdue" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_library_issue_form" model="ir.ui.view">
        <field name="name">library.book.issue.form</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <form string="Book Issue">
                <header>
                    <!-- Issue button — Reception + above -->
                    <button name="action_issue"
                            string="Issue Book"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="library_management.group_library_reception"/>


                    <!-- Issue button — Customer -->
                    <button name="action_issue"
                            string="Issue Book"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="library_management.group_library_customer"/>

                    <!-- Return button — Customer -->
                    <button name="action_return"
                            string="Return Book"
                            type="object"
                            invisible="state not in ('issued','overdue')"
                            groups="library_management.group_library_customer"/>

                    <!-- Return button — Reception + above -->
                    <button name="action_return"
                            string="Return Book"
                            type="object"
                            invisible="state not in ('issued','overdue')"
                            groups="library_management.group_library_reception"/>

                    <!-- Fine paid — Reception + above -->
                    <button name="action_mark_fine_paid"
                            string="Mark Fine Paid"
                            type="object"
                            invisible="fine_amount == 0 or fine_paid == True"
                            groups="library_management.group_library_reception"/>

                    <!-- Reset to Draft — Manager only -->
                    <button name="action_set_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'returned'"
                            groups="library_management.group_library_manager"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,issued,overdue,returned"/>
                </header>
                <sheet>
                    <group>
                        <group string="Book Details">
                            <field name="name" readonly="1"/>
                            <field name="book_id"
                                   options="{'no_create': True}"/>
                            <field name="available_qty"/>
                        </group>
                        <group string="Member Details">
                            <field name="member_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Dates">
                            <field name="issue_date"/>
                            <field name="due_date"/>
                            <field name="return_date" readonly="1"/>
                        </group>
                        <group string="Overdue Info">
                            <field name="is_overdue"/>
                            <field name="days_overdue"
                                   invisible="days_overdue == 0"/>
                        </group>
                    </group>

                    <!-- Payment / Fine Details — Reception + above -->
                    <group string="Payment Details"
                           groups="library_management.group_library_reception">
                        <group>
                            <field name="fine_rate"
                                   string="Fine Rate (Rs/day)"/>
                            <field name="fine_amount"
                                   string="Total Fine (Rs.)"/>
                            <field name="fine_paid"
                                   string="Fine Paid?"
                                   invisible="fine_amount == 0"/>
                        </group>
                        <group>
                            <field name="days_overdue"
                                   string="Days Overdue"
                                   invisible="days_overdue == 0"
                                   readonly="1"/>
                        </group>
                    </group>

                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_library_issue_search" model="ir.ui.view">
        <field name="name">library.book.issue.search</field>
        <field name="model">library.book.issue</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="book_id"/>
                <field name="member_id"/>
                <filter string="Issued" name="issued"
                        domain="[('state','=','issued')]"/>
                <filter string="Overdue" name="overdue"
                        domain="[('is_overdue','=',True)]"/>
                <filter string="Returned" name="returned"
                        domain="[('state','=','returned')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Member" name="grp_member"
                            context="{'group_by':'member_id'}"/>
                    <filter string="Book" name="grp_book"
                            context="{'group_by':'book_id'}"/>
                    <filter string="Status" name="grp_state"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- MAIN ACTION -->
    <record id="action_library_book_issues" model="ir.actions.act_window">
        <field name="name">Book Issues</field>
        <field name="res_model">library.book.issue</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_library_issue_search"/>
    </record>

</odoo>
