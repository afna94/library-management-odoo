<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════
         FORM VIEW — Book Master
    ══════════════════════════════════════ -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <!-- Smart buttons — existing button_box-ൽ inject -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_issues"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-book"
                        invisible="not is_library_book">
                    <field name="borrowed_copies"
                           string="Borrowed"
                           widget="statinfo"/>
                </button>
                <button name="action_view_issues"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-check-circle"
                        invisible="not is_library_book">
                    <field name="available_copies"
                           string="Available"
                           widget="statinfo"/>
                </button>
            </xpath>

            <!-- Is Library Book toggle — name field-ന് ശേഷം -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_library_book" widget="boolean_toggle"/>
            </xpath>

            <!-- Book Details page — notebook-ൽ first tab -->
            <xpath expr="//notebook/page[1]" position="before">
                <page string="Book Details" invisible="not is_library_book">
                    <group>
                        <group string="Author and Publication">
                            <field name="author"
                                   placeholder="e.g. Paulo Coelho"/>
                            <field name="publisher"
                                   placeholder="e.g. HarperCollins"/>
                            <field name="publication_year"/>
                            <field name="edition"
                                   placeholder="e.g. 3rd Edition"/>
                        </group>
                        <group string="Classification">
                            <field name="isbn"
                                   placeholder="e.g. 978-0-061-96436-9"/>
                            <field name="book_category"/>
                            <field name="language"/>
                        </group>
                    </group>
                    <group>
                        <group string="Stock Info">
                            <field name="total_copies"/>
                            <field name="borrowed_copies" readonly="1"/>
                            <field name="available_copies" readonly="1"/>
                        </group>
                    </group>
                </page>

                <!-- Issue History tab -->
                <page string="Issue History" invisible="not is_library_book">
                    <field name="product_variant_ids" invisible="1"/>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ══════════════════════════════════════
         LIST VIEW — Book Master
    ══════════════════════════════════════ -->
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Books"
                  decoration-success="available_copies &gt; 0"
                  decoration-danger="available_copies == 0">
                <field name="name" string="Book Title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="book_category"/>
                <field name="language"/>
                <field name="publisher"/>
                <field name="total_copies"/>
                <field name="borrowed_copies"/>
                <field name="available_copies"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════
         KANBAN VIEW — Customer view
    ══════════════════════════════════════ -->
    <record id="view_library_book_kanban" model="ir.ui.view">
        <field name="name">library.book.kanban</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="author"/>
                <field name="book_category"/>
                <field name="available_copies"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('product.template', 'image_128', record.id.raw_value)"
                                     alt="Book Cover"
                                     class="o_image_64_contain"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><i class="fa fa-user"/> <field name="author"/></div>
                                <div>
                                    <span class="badge text-bg-success"
                                          t-if="record.available_copies.raw_value &gt; 0">
                                        Available: <t t-esc="record.available_copies.value"/>
                                    </span>
                                    <span class="badge text-bg-danger"
                                          t-if="record.available_copies.raw_value == 0">
                                        Not Available
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════ -->
    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Book Title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="publisher"/>
                <filter string="Available" name="available"
                        domain="[('available_copies','>',0)]"/>
                <filter string="Not Available" name="not_available"
                        domain="[('available_copies','=',0)]"/>
                <filter string="Library Books" name="library_books"
                        domain="[('is_library_book','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="grp_category"
                            context="{'group_by':'book_category'}"/>
                    <filter string="Language" name="grp_language"
                            context="{'group_by':'language'}"/>
                    <filter string="Publisher" name="grp_publisher"
                            context="{'group_by':'publisher'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════ -->

    <!-- All books — Reception/Manager -->
    <record id="action_library_all_books" model="ir.actions.act_window">
        <field name="name">Books Master</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_library_book','=',True)]</field>
        <field name="context">{
            'default_is_library_book': True,
            'default_type': 'consu',
            'search_default_library_books': 1
        }</field>
        <field name="search_view_id" ref="view_library_book_search"/>
    </record>

    <!-- Available books — Customer -->
    <record id="action_library_available_books" model="ir.actions.act_window">
        <field name="name">Available Books</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list</field>
        <field name="domain">[('is_library_book','=',True),('available_copies','>',0)]</field>
        <field name="context">{'search_default_available': 1}</field>
        <field name="search_view_id" ref="view_library_book_search"/>
    </record>

    <!-- My borrow records — Customer -->
    <record id="action_my_borrow_records" model="ir.actions.act_window">
        <field name="name">My Borrow Records</field>
        <field name="res_model">library.book.issue</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('member_id.user_ids','in',[uid])]</field>
        <field name="context">{'default_member_id': uid}</field>
    </record>

</odoo>