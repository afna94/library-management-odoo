<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Root menu -->
  <menuitem id="menu_library_root"
            name="Library"
            sequence="10"/>

  <!-- ── Borrowing ── -->
  <menuitem id="menu_library_borrowing"
            name="Borrowing"
            parent="menu_library_root"
            sequence="10"/>

  <menuitem id="menu_library_issues"
            name="Book Issues"
            parent="menu_library_borrowing"
            action="action_library_book_issues"
            sequence="10"/>

  <menuitem id="menu_library_issued"
            name="Currently Issued"
            parent="menu_library_borrowing"
            action="action_library_issued_books"
            sequence="20"/>

  <menuitem id="menu_library_overdue"
            name="Overdue Books"
            parent="menu_library_borrowing"
            action="action_library_overdue_books"
            sequence="30"/>

  <!-- ── Purchase ── -->
  <menuitem id="menu_library_purchase"
            name="Purchase"
            parent="menu_library_root"
            sequence="20"/>

  <menuitem id="menu_library_rfq"
            name="Requests for Quotation"
            parent="menu_library_purchase"
            action="action_library_rfq"
            sequence="10"/>

  <menuitem id="menu_library_purchase_orders"
            name="Purchase Orders"
            parent="menu_library_purchase"
            action="action_library_purchase_orders"
            sequence="20"/>

  <!-- ── Sales ── -->
  <menuitem id="menu_library_sales"
            name="Sales"
            parent="menu_library_root"
            sequence="30"/>

  <menuitem id="menu_library_sale_orders"
            name="Sales Orders"
            parent="menu_library_sales"
            action="action_library_sale_orders"
            sequence="10"/>

  <menuitem id="menu_library_invoices"
            name="Invoices"
            parent="menu_library_sales"
            action="action_library_invoices"
            sequence="20"/>

</odoo>
