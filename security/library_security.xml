<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Module Category ── -->
    <record id="module_library_management" model="ir.module.category">
        <field name="name">Library Management</field>
        <field name="sequence">20</field>
    </record>

    <!-- ── 1. Customer ── -->
    <record id="group_library_customer" model="res.groups">
        <field name="name">Customer</field>
        <field name="category_id" ref="module_library_management"/>
        <field name="comment">Can view available books and their own borrow records.</field>
    </record>


    <!-- ── 1b. Customer Only ── -->
    <record id="group_library_customer_only" model="res.groups">
       <field name="name">Customer Only</field>
       <field name="category_id" ref="base.module_category_hidden"/>
       <field name="comment">Hidden group — My Borrow Records menu for customers only.</field>
    </record>

    <!-- ── 2. Receptionist ── -->
    <record id="group_library_reception" model="res.groups">
        <field name="name">Receptionist</field>
        <field name="category_id" ref="module_library_management"/>
        <field name="implied_ids" eval="[(4, ref('group_library_customer'))]"/>
        <field name="comment">Can issue/return books, collect fines, manage books, sale and purchase.</field>
    </record>

    <!-- ── 3. Manager ── -->
    <record id="group_library_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_library_management"/>
        <field name="implied_ids" eval="[(4, ref('group_library_reception'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Full access: all data, purchase, sales, reports, delete.</field>
    </record>

    <!-- ── 4. Admin ── -->
    <record id="group_library_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_library_management"/>
        <field name="implied_ids" eval="[(4, ref('group_library_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
